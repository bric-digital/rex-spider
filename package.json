{
    "name": "@bric/rex-spider",
    "version": "0.0.1",
    "description": "REX module that uses the extension to spider content from compatible sites.",
    "keywords": [
        "extension",
        "rex"
    ],
    "author": "Behavioral Research Innovation Center",
    "type": "module",
    "main": "index.mts",
    "homepage": "https://github.com/bric-digital/rex-spider",
    "bugs": {
        "url": "https://github.com/bric-digital/rex-spider/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/bric-digital/rex-spider.git"
    },
    "exports": {
        "./extension": "./src/extension.mts",
        "./browser": "./src/browser.mts",
        "./service-worker": "./src/service-worker.mts",
        "./spider": "./src/spider.mts"
    },
    "scripts": {
        "build": "tsc",
        "lint": "eslint src",
        "pretest": "node tests/scripts/build-test-bundle.js",
        "test": "playwright test",
        "test:ci": "playwright test --reporter=dot",
        "test:debug": "playwright test --debug",
        "test:headed": "playwright test --headed",
        "test:ui": "playwright test --ui",
        "test:unit": "playwright test specs/"
    },
    "dependencies": {
        "@bric/rex-core": "github:bric-digital/rex-core"
    }
}
